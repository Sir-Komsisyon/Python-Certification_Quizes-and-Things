def is_safe(queens, row, col):
    # Check all previously placed queens
    for r in range(row):
        c = queens[r]
        # same column
        if c == col:
            return False
        # same diagonal
        if abs(c - col) == abs(r - row):
            return False
    return True


def dfs_n_queens(n):
    if n < 1:
        return []
    
    solutions = []
    
    def dfs(row, queens):
        if row == n:
            solutions.append(queens[:])  # copy solution
            return
        for col in range(n):
            if is_safe(queens, row, col):
                queens[row] = col
                dfs(row + 1, queens)
    
    dfs(0, [-1] * n)  # start with empty board
    return solutions


# Example run
print(dfs_n_queens(4))
